# Пример переменных окружения для проекта "Банк лекций"
# Скопируйте этот файл в .env и заполните своими значениями

# База данных PostgreSQL
POSTGRES_USER=lecturebank_user
POSTGRES_PASSWORD=lecturebank_password
POSTGRES_DB=lecturebank_db

# Для прямого подключения (без Docker)
DATABASE_URL=postgresql://lecturebank_user:lecturebank_password@localhost:5432/lecturebank_db

# Безопасность JWT (используйте случайную строку в продакшне)
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI API (для ИИ функциональности)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Директория для загруженных файлов
UPLOAD_DIR=uploads
